# Grubble Eats marketing site — environment template.
# Copy to `.env` for local dev (never commit `.env`).
# In production, set these in the Cloudflare Pages dashboard → Settings → Environment variables.

# Brevo API key — used by functions/api/waitlist.ts to add waitlist contacts.
# The waitlist function degrades gracefully if this is unset (logs + returns 200).
BREVO_API_KEY=

# Optional: Brevo contact list id to add signups to. If unset, the contact is created without a list.
BREVO_LIST_ID=

# Optional: the allowed origin for the waitlist endpoint CORS. Defaults to https://grubbleeats.com.
ALLOWED_ORIGIN=http://localhost:4321
