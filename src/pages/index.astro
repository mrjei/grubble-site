---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureStrip from '../components/FeatureStrip.astro';
import WhatItDoes from '../components/WhatItDoes.astro';
import EmailCapture from '../components/EmailCapture.astro';
import Footer from '../components/Footer.astro';
import config from '../data/config.json';
---

<BaseLayout title={config.seo.homeTitle} description={config.seo.homeDescription}>
  <main>
    <Hero />
    <FeatureStrip />
    <WhatItDoes />
    <EmailCapture />
  </main>
  <Footer />
</BaseLayout>
