---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import config from '../data/config.json';

// Quick stats — keep these honest. Pre-launch, solo-founded, real working demo.
const stats = [
  { value: 'Pre-launch', label: 'Public web beta live; native iOS + Android next' },
  { value: 'Solo founder', label: 'AI-augmented, built end to end by one person' },
  { value: '50+', label: 'Real restaurants live in the Port St. Lucie deck' },
  { value: '4', label: 'AI surfaces running on real Anthropic Claude' },
];

// Screenshots: pull real high-res captures into public/screenshots/ before press
// outreach. These are intentional placeholders until then — see TODO below.
// TODO(James): drop real PWA screenshots into public/screenshots/ and the grid
// will render them. Suggested set: deck card, group session, AI recommender,
// tiebreaker, restaurant detail with vibe preview. Recommended ~1290×2796
// (iPhone) or similar, PNG.
const screenshots = [
  { src: '/screenshots/deck.png', alt: 'Grubble Eats restaurant swipe deck' },
  { src: '/screenshots/group-session.png', alt: 'Grubble Eats live group session' },
  { src: '/screenshots/ai-recommender.png', alt: 'Grubble Eats AI recommender' },
  { src: '/screenshots/restaurant-detail.png', alt: 'Grubble Eats restaurant detail with AI vibe preview' },
];
---

<BaseLayout
  title="Press & Investors — Grubble Eats"
  description="Press, investor, and recruiter resources for Grubble Eats — the AI-powered group food decision app. Tech stack, founder bio, live demo, and contact."
>
  <header class="px-6 py-6 border-b border-border-subtle">
    <a href="/" class="inline-flex items-center gap-3" aria-label="Grubble Eats home">
      <BrandMark variant="squircle" size={36} title="Grubble Eats" class="rounded-md" />
      <span class="font-display font-extrabold text-lg">Grubble Eats</span>
    </a>
  </header>

  <main class="px-6 py-16">
    <article class="mx-auto max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-wide text-text-tertiary">
        Press &amp; investors
      </p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tightest text-balance">
        Grubble Eats — the group food decision app
      </h1>
      <p class="mt-4 text-lg text-text-secondary text-pretty">
        Swipe together. Match together. Eat together. A working, demo-grade
        product built on real restaurant data and real AI — not a prototype.
      </p>

      <div class="mt-8">
        <Button href={config.urls.appDemo} target="_self" size="default">
          Open the live demo
        </Button>
        <span class="ml-3 text-sm text-text-tertiary">app.grubbleeats.com</span>
      </div>

      <!-- Quick stats -->
      <section class="mt-14">
        <h2 class="sr-only">Quick stats</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            stats.map((stat) => (
              <div class="rounded-lg border border-border-subtle bg-bg-raised p-5">
                <p class="font-display text-2xl font-extrabold tracking-tightest text-primary">
                  {stat.value}
                </p>
                <p class="mt-1 text-sm leading-snug text-text-secondary text-pretty">
                  {stat.label}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <div class="mt-14 space-y-12 text-base leading-relaxed text-text-secondary [&_h2]:text-2xl [&_h2]:font-display [&_h2]:font-extrabold [&_h2]:tracking-tightest [&_h2]:text-text-primary [&_h2]:mb-3 [&_a]:text-primary [&_a]:underline">
        <section>
          <h2>Tech stack</h2>
          <p>
            Grubble Eats is a Flutter app (one codebase for web, iOS, and
            Android) backed by Cloudflare — Workers and D1 for live group-session
            sync and the waitlist, Pages for the marketing site. The AI surfaces
            run on real Anthropic Claude (Haiku for fast card blurbs and vibe
            previews, Sonnet streaming for the recommender and tiebreaker), and
            every restaurant is real, live data from the Google Places API.
            Spend is tracked through dedicated cost-monitoring endpoints.
          </p>
        </section>

        <section>
          <h2>Live demo</h2>
          <p>
            The product is best understood by using it. The web beta is open at
            <a href={config.urls.appDemo} rel="noopener noreferrer">app.grubbleeats.com</a>
            — swipe a real deck, start a group session, and watch Claude explain
            the winning pick.
          </p>
        </section>

        <section>
          <h2>Screenshots</h2>
          <p>
            High-resolution screenshots of the live app. For other formats or
            assets, email
            <a href={`mailto:${config.contact.support}`}>{config.contact.support}</a>.
          </p>
          <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
            {
              screenshots.map((shot) => (
                <figure class="overflow-hidden rounded-lg border border-border-subtle bg-surface-muted">
                  {/* TODO(James): add real captures to public/screenshots/ — placeholders until then. */}
                  <img
                    src={shot.src}
                    alt={shot.alt}
                    loading="lazy"
                    class="aspect-[9/19] w-full bg-surface-sunken object-cover"
                  />
                </figure>
              ))
            }
          </div>
          <p class="mt-3 text-sm text-text-tertiary">
            Placeholder slots — real captures land in <code class="font-mono">public/screenshots/</code> before press outreach.
          </p>
        </section>

        <section>
          <h2>Founder</h2>
          <p>
            <strong class="text-text-primary">James Blanchard</strong> — founder,
            Port St. Lucie, Florida. James builds AI infrastructure under the
            <a href={config.urls.parent} rel="noopener noreferrer">Tenvaro</a>
            umbrella and ships full products solo, AI-augmented, end to end.
            Grubble Eats is built nights and weekends alongside a day job in
            healthcare technology.
          </p>
        </section>

        <section>
          <h2>Contact</h2>
          <p>
            Press, investor, and recruiter inquiries:
            <a href={`mailto:${config.contact.support}`}>{config.contact.support}</a>.
          </p>
        </section>
      </div>

      <p class="mt-12">
        <a href="/" class="text-primary font-bold underline">&larr; Back to home</a>
      </p>
    </article>
  </main>

  <Footer />
</BaseLayout>
