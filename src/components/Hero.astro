---
// Hero copy LOCKED 2026-05-31 (James workshopped + locked).
// Earlier headline variants live in git history (Variant C — the chant — won).
// Brand name sits in HEAD metadata (title / og / structured data) for SEO; the
// hero visual stays clean — the Fork-G mark above carries the brand here.
import BrandMark from './BrandMark.astro';
import Button from './Button.astro';
import config from '../data/config.json';
---

<section class="relative overflow-hidden px-6 pt-20 pb-16 sm:pt-28 sm:pb-24">
  <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
    <BrandMark variant="squircle" size={88} title="Grubble Eats" class="mb-8 shadow-lg rounded-2xl" />

    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tightest text-balance">
      Swipe together.<br />
      Match together.<br />
      Eat together.
    </h1>

    <p class="hero-subhead mt-6 max-w-xl text-lg sm:text-xl text-text-secondary text-pretty">
      The AI-powered food decision app built for groups, not just solo discovery.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:gap-5">
      <div class="flex flex-col items-center gap-1.5">
        <Button href={config.urls.appDemo} target="_self" size="default">
          Try the demo
        </Button>
        <span class="text-sm text-text-tertiary">Free demo — early access</span>
      </div>

      <Button href="#waitlist" variant="secondary" size="default">
        Get notified
      </Button>
    </div>

    <p class="mt-12 text-sm font-medium uppercase tracking-wide text-text-tertiary">
      Coming soon to iOS and Android
    </p>
  </div>
</section>
