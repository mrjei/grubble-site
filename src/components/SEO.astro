---
/**
 * SEO — single source of truth for <head> metadata. BaseLayout delegates all
 * SEO to this component; pages pass only `title` / `description` (or nothing,
 * to fall back to the config defaults). All values resolve from config.json.
 *
 * Brand sits in HEAD metadata (title, og:site_name, structured data) for SEO
 * while the hero visual stays clean.
 */
import config from '../data/config.json';

interface Props {
  title?: string;
  description?: string;
  /** Per-page Open Graph image override (absolute path or full URL). */
  ogImage?: string;
}

const {
  title = config.seo.defaultTitle,
  description = config.business.description,
  ogImage: ogImageProp = config.seo.defaultOgImage,
} = Astro.props;

const siteUrl = config.urls.site;
const canonical = new URL(Astro.url.pathname, siteUrl).href;
// TODO(James): replace /og-image.png (brand card) with a recent high-res
// screenshot of the live PWA at app.grubbleeats.com once one is captured, then
// drop it in public/ and point config.seo.defaultOgImage at it. Brand card
// stands in for now — it's a real card, not a broken placeholder.
const ogImage = new URL(ogImageProp, siteUrl).href;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: config.business.name,
    url: siteUrl,
    logo: new URL('/apple-touch-icon.png', siteUrl).href,
    parentOrganization: {
      '@type': 'Organization',
      name: config.brand.parent,
      url: config.urls.parent,
    },
    sameAs: [config.urls.parent],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: config.business.name,
    url: siteUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: config.business.name,
    applicationCategory: 'FoodAndDrinkApplication',
    operatingSystem: 'iOS, Android, Web',
    url: config.urls.appDemo,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    description: config.business.description,
    publisher: {
      '@type': 'Organization',
      name: config.brand.parent,
      url: config.urls.parent,
    },
  },
];
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={config.business.name} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${config.business.name} — ${config.business.tagline}`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={`${config.business.name} — ${config.business.tagline}`} />

<!-- Application name (browser bookmarks, PWA hints) -->
<meta name="application-name" content={config.business.name} />
<meta name="apple-mobile-web-app-title" content={config.business.name} />

<!-- Structured data -->
{structuredData.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
))}
