---

<ul class={`flex items-center gap-4 ${className ?? ''}`}>
  {
    config.social.map((s) => (
      <li>
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Grubble Eats on ${s.platform}`}
          class="block text-text-tertiary transition-colors duration-base ease-standard hover:text-text-primary"
        >
          <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d={ICONS[s.platform]} />
          </svg>
        </a>
      </li>
    ))
  }
</ul>
