---
import BrandMark from './BrandMark.astro';
import SocialLinks from './SocialLinks.astro';
import config from '../data/config.json';

const year = new Date().getFullYear();
---

<footer class="border-t border-border-subtle px-6 py-12">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-6 sm:flex-row sm:justify-between">
    <div class="flex items-center gap-3">
      <BrandMark variant="squircle" size={36} title="Grubble Eats" class="rounded-md" />
      <span class="text-sm text-text-secondary">
        &copy; {year} Grubble Eats&trade; &middot; {config.brand.parent}
      </span>
    </div>

    <SocialLinks size={20} class="order-last sm:order-none" />

    <nav aria-label="Footer" class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
      <a href="/about" class="text-text-secondary transition-colors duration-base hover:text-text-primary">
        About
      </a>
      <a href="/press" class="text-text-secondary transition-colors duration-base hover:text-text-primary">
        Press
      </a>
      <a href="/faq" class="text-text-secondary transition-colors duration-base hover:text-text-primary">
        FAQ
      </a>
      <a href="/privacy" class="text-text-secondary transition-colors duration-base hover:text-text-primary">
        Privacy Policy
      </a>
      <a href="/terms" class="text-text-secondary transition-colors duration-base hover:text-text-primary">
        Terms of Service
      </a>
      <a
        href={`mailto:${config.contact.email}`}
        class="text-text-secondary transition-colors duration-base hover:text-text-primary"
      >
        {config.contact.email}
      </a>
    </nav>
  </div>
</footer>
